# ============================================================
# MSME Credit Intelligence Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─────────────────────────────────────────────────────────────
# DATABASE (Supabase Free Tier)
# Get from: https://app.supabase.com → Project → Settings → Database
# Use the "URI" connection string (Transaction pooler, port 6543)
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-a-strong-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────────────────────────
# GOOGLE GEMINI (Free Tier — 15 RPM, 1M tokens/day)
# Get from: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-studio-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────────────────────
# RABBITMQ
# Local dev: use Docker (docker-compose up rabbitmq)
# Deploy:    get from https://www.cloudamqp.com (free "Little Lemur" plan)
# ─────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ─────────────────────────────────────────────────────────────
# REDIS
# Local dev: use Docker (docker-compose up redis)
# Deploy:    get from https://upstash.com (free tier, 10k cmds/day)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# FILE STORAGE
# Phase 1-6: local filesystem
# Phase 7+:  GCS bucket (STORAGE_BUCKET=your-bucket-name)
# ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
STORAGE_TYPE=local
STORAGE_BUCKET=your-gcs-bucket-name

# ─────────────────────────────────────────────────────────────
# GCP (Phase 7 — Cloud Run Deploy)
# Get service account JSON from: https://console.cloud.google.com
# ─────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=./infra/gcp-service-account.json

# ─────────────────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# CORS (add your frontend URL here)
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
